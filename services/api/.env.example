# Story Simulator 后端环境变量配置
# 复制此文件为 .env 并填入实际值: cp .env.example .env

# === LLM 配置 (必填) ===
# OpenAI API Key — 从 https://platform.openai.com/api-keys 获取
OPENAI_API_KEY=sk-your-api-key-here

# 模型选择 (可选，默认 gpt-4o-mini)
# 开发调试: gpt-4o-mini (便宜快速)
# 正式使用: gpt-4o (更好的质量)
LLM_MODEL=gpt-4o-mini

# === 数据库 (本地开发用默认值即可) ===
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/story_simulator

# === Redis ===
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
